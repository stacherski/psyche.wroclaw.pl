<nav class="bcrumb" aria-label="Breadcrumb">
  <div>
    <ul class="breadcrumb">
      <li>
        <a href="/">Psyche</a>
      </li>
      {% if page.url and page.url.startsWith('/o-nas') %}
        <li>
          <a href="/o-nas">O nas</a>
        </li>
        {% if page.url.startsWith('/o-nas/artykuly') %}
          <li>
            <a href="/o-nas/artykuly">Artykuły</a>
          </li>
          {% if page.url !== '/o-nas/artykuly/' and article %}
            <li>{{ article.title }}</li>
          {% endif %}
        {% endif %}
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/kontakt')
 %}
        <li>
          <a href="/kontakt">Kontakt</a>
        </li>
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/pracuj')
 %}
        <li>
          <a href="/pracuj-z-nami">Pracuj z nami</a>
        </li>
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/regulamin')
 %}
        <li>
          <a href="/regulamin">Regulamin</a>
        </li>
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/cennik')
 %}
        <li>
          <a href="/cennik">Cennik</a>
        </li>
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/polityka')
 %}
        <li>
          <a href="/polityka-ochrony-małoletnich">Polityka Ochrony Małoletnich</a>
        </li>
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/oferta')
 %}
        <li>
          <a href="/oferta">Oferta</a>
        </li>
        {% if page.url !== '/oferta' %}
          {% for service in services %}
            {% if ('/oferta/' + (
            service.fullName | slugify) + '/') == page.url %}
              <li>{{ service.fullName }}</li>
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/zespół')
 %}
        <li>
          <a href="/zespół">Zespół</a>
        </li>
        {% if page.url !== '/zespół' %}
          {% for member in team %}
            {% if ('/zespół/' + (
            member.fullName | slugify) + '/') == page.url %}
              <li>{{ member.fullName }}</li>
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}
      {% if page
        .url and page
        .url
        .startsWith('/gabinety')
 %}
        <li>
          <a href="/gabinety">Gabinety</a>
        </li>
        {% if page.url !== '/gabinety/' %}
          {% for location in locations %}
            {% if ('/gabinety/' + (
            location.fullName | slugify) + '/') == page.url %}
              <li>{{ location.fullName }}</li>
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}
    </ul>
  </div>
</nav>
{% if service and service.prices %}
  {% set prices = collections.pricesPages | byServicePrices(service.prices) %}
{% endif %}

<table class="table prices">
  <thead>
    <tr>
      <th>Usługa</th>
      <th>Czas trwania</th>
      <th class="right">Cena</th>
    </tr>
  </thead>
  <tbody>
    {%- for price in prices -%}
      <tr>
        <td>
          {{ price.fullName }}
          {% if price.description %}
            <br /><span style="font-weight: 400;">{{
              price.description
            }}</span>{% endif %}
        </td>
        <td>
          {% if price.duration %}{{ price.duration }} minut{% endif %}
        </td>
        <td class="right">{{ price.price }} zł</td>
      </tr>
    {%- endfor -%}
  </tbody>
</table>

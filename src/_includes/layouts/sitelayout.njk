<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <link
      rel="shortcut icon"
      type="image/svg+xml"
      href="/media/psyche-favicon.svg"
    >
    <title>{{ pageTitle }} | {{ postfix }}</title>
    {# Google Site Verification #}
    <meta
      name="google-site-verification"
      content="DI1ldSgLOP1wL83v-NvrbF44G-SxWtnefJogD0QvC9k"
    >
    <meta
      name="google-site-verification"
      content="21qbgMgxZtLbWwl4AMb88lnijPJL8F0oxvXJqLex2YU"
    >
    <meta name="msvalidate.01" content="6A3F181E29D1D78CE723E40200A5F885">

    {# fonts definition #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    >

    {# Main CSS file #}
    <link rel="stylesheet" href="../../css/main.css">
    <link rel="stylesheet" href="../../css/page-header.css">
    <link rel="stylesheet" href="../../css/mobile-nav-bottom.css">
    <link rel="stylesheet" href="../../css/typographies.css">
    <link rel="stylesheet" href="../../css/bcrumb.css">
    <link rel="stylesheet" href="../../css/nav.css">
    <link rel="stylesheet" href="../../css/team.css">
    <link rel="stylesheet" href="../../css/services.css">

    {# Main JS file #}
    <script src="../../script/main.js"></script>
  </head>

  <body>
    {% include "partials/topbar.njk" %}
    <main>
      {# homepage video #}
      {% if isHomepage %}
        {% include "partials/homepage-video.njk" %}
      {% else %}
        {% include "partials/page-header.njk" %}
        {% include "partials/bcrumb.njk" %}
      {% endif %}

      {% block content %}
        {% include "partials/page-content.njk" %}
      {% endblock %}
    </main>
    {% include "partials/footer.njk" %}
  </body>
</html>
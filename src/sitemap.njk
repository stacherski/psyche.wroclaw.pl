  {# ── Services ──────────────────────────────────────────────────────────── #}
  {%- for service in services %}
    {%- if service.published %}
  <url>
    <loc>https://psyche.wroclaw.pl/oferta/{{ service.fullName | slugify }}/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
    {%- endif %}
  {%- endfor %}

  {# ── Team members ──────────────────────────────────────────────────────── #}
  {%- for member in team %}
    {%- if member.published == 'Yes' %}
  <url>
    <loc>https://psyche.wroclaw.pl/zesp%C3%B3%C5%82/{{ member.fullName | slugify }}/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
    {%- endif %}
  {%- endfor %}

  {# ── Locations ─────────────────────────────────────────────────────────── #}
  {%- for location in locations %}
    {%- if location.published %}
  <url>
    <loc>https://psyche.wroclaw.pl/gabinety/{{ location.fullName | slugify }}/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
    {%- endif %}
  {%- endfor %}

  {# ── Articles ──────────────────────────────────────────────────────────── #}
  {%- for article in articles %}
    {%- if article.published %}
  <url>
    <loc>https://psyche.wroclaw.pl/o-nas/artykuly/@{{ article.id }}/{{ article.urlTitle | slugify }}/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
    {%- endif %}
  {%- endfor %}

